{
  "name": "latex-preview-editor",
  "displayName": "LaTeX Preview Editor",
  "description": "Overleaf-style hybrid WYSIWYG LaTeX editor",
  "version": "0.0.5",
  "repository": {
    "type": "git",
    "url": "https://github.com/joon-klaps/latex-preview-editor-vscode.git"
  },
  "publisher": "joon-klaps",
  "License": "MIT",
  "engines": {
    "vscode": "^1.116.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "latex-preview.editor",
        "displayName": "LaTeX Preview Editor",
        "selector": [
          {
            "filenamePattern": "*.tex"
          }
        ],
        "priority": "default"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "latex-preview-sidebar",
          "title": "LaTeX Preview",
          "icon": "assets/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "latex-preview-sidebar": [
        {
          "type": "webview",
          "id": "latex-preview.settings",
          "name": "LaTeX Preview"
        }
      ]
    },
    "configuration": {
      "title": "LaTeX Preview Editor",
      "properties": {
        "latex-preview-editor.contentWidth": {
          "type": "string",
          "default": "780px",
          "enum": [
            "680px",
            "780px",
            "960px",
            "1200px",
            "100%"
          ],
          "description": "Default editor content width."
        },
        "latex-preview-editor.completionBackend": {
          "type": "string",
          "default": "claude",
          "enum": ["claude", "ollama"],
          "enumDescriptions": [
            "Use Anthropic claude-haiku-4-5 via the API (set ANTHROPIC_API_KEY or claudeApiKey)",
            "Use a local Ollama model (configure ollamaUrl and ollamaModel)"
          ],
          "description": "Which backend to use for inline completions."
        },
        "latex-preview-editor.claudeApiKey": {
          "type": "string",
          "default": "",
          "description": "Anthropic API key for Claude completions. Falls back to the ANTHROPIC_API_KEY environment variable if empty."
        },
        "latex-preview-editor.ollamaUrl": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "Base URL of the local Ollama server."
        },
        "latex-preview-editor.ollamaModel": {
          "type": "string",
          "default": "",
          "description": "Ollama model for inline completions (e.g. granite-code:3b). Pull the model first via `ollama pull <model>`."
        },
        "latex-preview-editor.ollamaMaxTokens": {
          "type": "number",
          "default": 150,
          "minimum": 25,
          "maximum": 512,
          "description": "Maximum tokens to generate per inline completion."
        },
        "latex-preview-editor.ollamaFimFormat": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "granite",
            "qwen",
            "deepseek",
            "codellama",
            "starcoder",
            "chat"
          ],
          "enumDescriptions": [
            "Detect format from model name",
            "IBM Granite-code (<fim_prefix>/<fim_suffix>/<fim_middle>)",
            "Qwen2.5-Coder (<|fim_prefix|>/<|fim_suffix|>/<|fim_middle|>)",
            "DeepSeek-Coder (<｜fim▁begin｜>/<｜fim▁hole｜>/<｜fim▁end｜>)",
            "CodeLlama code (<PRE>/<SUF>/<MID>)",
            "StarCoder2 (<fim_prefix>/<fim_suffix>/<fim_middle>)",
            "Chat fallback — use /api/chat instead of FIM"
          ],
          "description": "FIM token format to use. 'auto' detects from the model name."
        }
      }
    }
  },
  "scripts": {
    "build": "node build.mjs",
    "watch": "node build.mjs --watch"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.116.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@codemirror/autocomplete": "^6.20.2",
    "@codemirror/commands": "^6.0.0",
    "@codemirror/language": "^6.0.0",
    "@codemirror/legacy-modes": "^6.0.0",
    "@codemirror/merge": "^6.12.1",
    "@codemirror/state": "^6.0.0",
    "@codemirror/view": "^6.0.0",
    "@marimo-team/codemirror-ai": "^0.3.7",
    "codemirror": "^6.0.0",
    "katex": "^0.16.0"
  }
}
